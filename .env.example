# Airtable Configuration
# Get your API key from https://airtable.com/api
GATSBY_AIRTABLE_API=your_airtable_api_key_here
NEXT_PUBLIC_AIRTABLE_API=your_airtable_api_key_here

# Important: In Next.js, only NEXT_PUBLIC_ variables are available on the client side
# GATSBY_AIRTABLE_API is kept for server-side compatibility with existing code

# Note: Create a .env.local file with your actual values
# .env.local is already added to .gitignore