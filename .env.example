# Airtable Configuration
# Get your API key from https://airtable.com/api
GATSBY_AIRTABLE_API=your_airtable_api_key_here
NEXT_PUBLIC_AIRTABLE_API=your_airtable_api_key_here

# Important: In Next.js, only NEXT_PUBLIC_ variables are available on the client side
# GATSBY_AIRTABLE_API is kept for server-side compatibility with existing code

# NextAuth Configuration
# Generate a secret with: openssl rand -base64 32
AUTH_SECRET=your_nextauth_secret_here

# Google OAuth Configuration
# Get credentials from: https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=your_google_client_id_here
AUTH_GOOGLE_SECRET=your_google_client_secret_here

# Admin Email Addresses (comma-separated)
# Only these email addresses will be allowed to access the admin panel
ALLOWED_ADMIN_EMAILS=admin@example.com,another-admin@example.com

# Note: Create a .env.local file with your actual values
# .env.local is already added to .gitignore
